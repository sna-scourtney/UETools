#
# Settings for "direnv" to automatically load the project's
# uv-managed virtual environment (kept at "venv" instead of the
# uv default ".venv" - this repo prefers visible directories with
# .gitignore over dotfiles).
#
export UV_PROJECT_ENVIRONMENT="venv"
export VIRTUAL_ENV="$PWD/venv"
PATH_add "$VIRTUAL_ENV/bin"
